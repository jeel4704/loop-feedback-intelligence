generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String                @id @default(cuid())
  name         String?
  email        String                @unique
  passwordHash String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  memberships  WorkspaceMembership[]
  conversations Conversation[]
  aiUsages      AIUsage[]
  imports       Import[]
}

model Workspace {
  id          String                @id @default(cuid())
  name        String
  slug        String                @unique
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  feedback    Feedback[]
  invitations Invitation[]
  reports     Report[]
  themes      Theme[]
  members     WorkspaceMembership[]
  activityLogs ActivityLog[]
  conversations Conversation[]
  aiUsages      AIUsage[]
  imports       Import[]
}

model WorkspaceMembership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        Role
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Feedback {
  id             String          @id @default(cuid())
  workspaceId    String
  title          String
  content        String
  sentiment      Float?
  sentimentLabel String?
  intent         String?
  tags           String[]
  reason         String?
  source         String          @default("MANUAL")
  status         String          @default("New")
  occurrenceCount Int             @default(1)
  lastReportedAt  DateTime        @default(now())
  duplicateOf     String?
  similarityScore Float?
  customerName   String?
  customerEmail  String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  embedding      Embedding?
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  themes         FeedbackTheme[]

  @@index([workspaceId])
  @@index([createdAt])
  @@index([sentiment])
}

model Embedding {
  id         String                 @id @default(cuid())
  feedbackId String                 @unique
  vector     Unsupported("vector")?
  feedback   Feedback               @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
}

model Theme {
  id          String          @id @default(cuid())
  workspaceId String
  name        String
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  feedback    FeedbackTheme[]
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model FeedbackTheme {
  feedbackId String
  themeId    String
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  theme      Theme    @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@id([feedbackId, themeId])
  @@index([themeId])
}

model Report {
  id          String       @id @default(cuid())
  workspaceId String
  title       String
  summary     String
  status      ReportStatus @default(DRAFT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

model Import {
  id              String       @id @default(cuid())
  workspaceId     String
  fileName        String
  importedBy      String
  validRecords    Int          @default(0)
  invalidRecords  Int          @default(0)
  status          String       @default("COMPLETED")
  fileSize        Int          @default(0)
  duration        Int          @default(0)
  source          String       @default("CSV")
  createdAt       DateTime     @default(now())
  
  workspace       Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [importedBy], references: [id], onDelete: Cascade)
  
  @@index([workspaceId])
}

model PendingWorkspace {
  id            String   @id @default(cuid())
  workspaceName String
  name          String
  email         String   @unique
  passwordHash  String
  code          String
  expiresAt     DateTime
  createdAt     DateTime @default(now())
}

// PendingUser model for magic‑link signup flow
model PendingUser {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  workspaceName String?
  passwordHash String
  token        String   @unique
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime @default(now())
}

model Invitation {
  id          String    @id @default(cuid())
  email       String
  workspaceId String
  role        Role
  token       String    @unique
  code        String
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  acceptedAt  DateTime?
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
}

model OTPVerification {
  id        String   @id
  email     String   @unique
  hashedOtp String
  purpose   String
  expiresAt DateTime
  attempts  Int      @default(0)
  resends   Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

enum Role {
  OWNER
  ADMIN
  ANALYST
  VIEWER
}



enum ReportStatus {
  DRAFT
  READY
  ARCHIVED
}

model ActivityLog {
  id          String     @id @default(cuid())
  workspaceId String?
  label       String
  timeLabel   String     @default("Just now")
  createdAt   DateTime   @default(now())
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
}

// ==========================================
// ASK LOOP AI MODELS
// ==========================================

model Conversation {
  id          String    @id @default(cuid())
  title       String    @default("New Conversation")
  userId      String
  workspaceId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages    Message[]
  aiUsage     AIUsage[]

  @@index([userId])
  @@index([workspaceId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String       @db.Text
  tokens         Int?
  createdAt      DateTime     @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  attachments    Attachment[]
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Attachment {
  id         String   @id @default(cuid())
  messageId  String
  fileName   String
  fileUrl    String
  fileType   String
  createdAt  DateTime @default(now())

  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model AIUsage {
  id             String       @id @default(cuid())
  workspaceId    String
  userId         String
  conversationId String?
  promptTokens   Int
  completionTokens Int
  totalTokens    Int
  model          String
  createdAt      DateTime     @default(now())

  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
}
