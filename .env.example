# App
NEXT_PUBLIC_APP_NAME="LOOP AI Customer Feedback Intelligence Platform"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/loop_ai"

# Auth.js / NextAuth
AUTH_SECRET="replace-with-a-long-random-string"
AUTH_TRUST_HOST="true"
GITHUB_ID=""
